{
  "name": "jbg-architects",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate:types && npm run generate:importmap && next build",
    "start": "next start",
    "lint": "next lint",
    "generate:types": "node --import tsx node_modules/payload/bin.js generate:types --disable-transpile",
    "generate:importmap": "node --import tsx node_modules/payload/bin.js generate:importmap --disable-transpile",
    "postinstall": "node scripts/patch-payload.cjs"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.82.1",
    "@payloadcms/next": "^3.82.1",
    "@payloadcms/richtext-lexical": "^3.82.1",
    "@payloadcms/storage-vercel-blob": "^3.82.1",
    "@payloadcms/ui": "^3.82.1",
    "@sanity/client": "^7.21.0",
    "@sanity/image-url": "^2.1.1",
    "framer-motion": "^11.0.0",
    "groq": "^5.20.0",
    "next": "~15.4.11",
    "next-sanity": "^12.2.2",
    "payload": "^3.82.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
